{
    "data_report_segmenter": {
        "name": "data_report_segmenter",
        "display_name": "Data Report Segmenter",
        "type": "PRO",
        "visibility": "PUB",
        "allow_many": true,
        "description": "Segments a single timeline into operator-labelled kinds and generates per-kind CSV reports of ui_state NumericVariables",
        "long_description": "README.md",
        "depends_on": [],
        "owner_org_key": "36a22e32-ab81-4a39-b400-869d532a052d",
        "repo_branch": "main",
        "handler": "src.data_report_segmenter.handler",
        "lambda_config": {
            "Runtime": "python3.13",
            "Timeout": 300,
            "MemorySize": 256,
            "Handler": "src.data_report_segmenter.handler"
        },
        "staging_config": {
            "id": 202988397197834758,
            "lambda_config": {
                "Environment": {
                    "Variables": {
                        "DOOVER_DATA_ENDPOINT": "https://data.staging.udoover.com/api"
                    }
                },
                "Runtime": "python3.13",
                "Timeout": 300,
                "Handler": "src.data_report_segmenter.handler",
                "MemorySize": 256
            }
        },
